#. Translators: Script category for commands to insert symbols.
#: addon\globalPlugins\copySymbol\__init__.py:17
msgid "Copy symbols"
msgstr ""

#. Just set the doc string of the script, using the decorator is overkill here.
#. Translators: Message presented in input help mode.
#: addon\globalPlugins\copySymbol\__init__.py:60
#, python-format
msgid "Copies the %s symbol and pastes it from the clipboard"
msgstr ""

#. Translators: (emoji) Grinning face, an happy face with normal eyes.
#: addon\globalPlugins\emoticons\smileysList.py:13
msgid "Grinning face"
msgstr "咧嘴大笑的臉"

#. Translators: (emoji) Happy face with open mouth and squinting eyes.
#: addon\globalPlugins\emoticons\smileysList.py:15
msgid "Happy face with open mouth and squinting eyes"
msgstr "開口大笑且瞇著眼的開心表情"

#. Translators: (emoji) happy face with open mouth.
#: addon\globalPlugins\emoticons\smileysList.py:17
msgid "Happy face with open mouth"
msgstr "張大口大笑的開心表情"

#. Translators: (emoji) A smiling face with smiling eyes and rosy cheeks.
#: addon\globalPlugins\emoticons\smileysList.py:19
msgid "Smiling Face With Smiling Eyes"
msgstr "帶有笑眼的微笑表情"

#. Translators: (emoji) smirking face.
#: addon\globalPlugins\emoticons\smileysList.py:21
msgid "Smirking face"
msgstr "歪嘴微笑的得意表情"

#. Translators: (emoji) Slightly Smiling Face: a face that is a little bit happy, with a slight smile and neutral eyes.
#: addon\globalPlugins\emoticons\smileysList.py:23
msgid "Slightly smiling face"
msgstr "略帶微笑的平淡表情"

#. Translators: (emoji) white smiling face.
#: addon\globalPlugins\emoticons\smileysList.py:25
msgid "white smiling face"
msgstr "空心線條的微笑符號"

#. Translators: (emoji) happy face with halo.
#: addon\globalPlugins\emoticons\smileysList.py:27
msgid "Happy face with halo"
msgstr "帶有頭頂光環的聖潔表情"

#. Translators: (emoji) white frowning face.
#: addon\globalPlugins\emoticons\smileysList.py:29
msgid "White frowning face"
msgstr "空心線條的憂愁表情"

#. Translators: (emoji) winking face.
#: addon\globalPlugins\emoticons\smileysList.py:31
msgid "Winking face"
msgstr "單眼眨眼示意的小調皮表情"

#. Translators: (emoji) smiling face with heart shaped eyes.
#: addon\globalPlugins\emoticons\smileysList.py:33
msgid "Smiling face with heart shaped eyes"
msgstr "帶有愛心形狀雙眼的幸福表情"

#. Translators: (emoji)  Rose: a single red rose.
#: addon\globalPlugins\emoticons\smileysList.py:35
msgid "Rose"
msgstr "盛開的紅色玫瑰花"

#. Translators: (emoji) Expressionless face: a face with straight lined eyes and mouth. A deliberate display of no comment...
#: addon\globalPlugins\emoticons\smileysList.py:37
msgid "Expressionless face"
msgstr "毫無表情且眼神冷淡的臉"

#. Translators: (emoji) neutral face.
#: addon\globalPlugins\emoticons\smileysList.py:39
msgid "Neutral face"
msgstr "中性且表情平靜的臉"

#. Translators: (emoji) face without mouth.
#: addon\globalPlugins\emoticons\smileysList.py:41
msgid "Face without mouth"
msgstr "沒有嘴巴且保持沉默的臉"

#. Translators: (emoji) face throwing a kiss.
#: addon\globalPlugins\emoticons\smileysList.py:43
msgid "Face throwing a kiss"
msgstr "單眼眨眼且送出飛吻的親親表情"

#. Translators: (emoji) kissing face with closed eyes.
#: addon\globalPlugins\emoticons\smileysList.py:45
msgid "Kissing face with closed eyes"
msgstr "雙眼閉起且嘟嘴的親親表情"

#. Translators: (emoji) Kissing face.
#: addon\globalPlugins\emoticons\smileysList.py:47
msgid "Kissing face"
msgstr "圓眼嘟嘴的親親表情"

#. Translators: (emoji) kissing face with arched eyes.
#: addon\globalPlugins\emoticons\smileysList.py:49
msgid "Kissing face with arched eyes"
msgstr "帶有彎彎笑眼且嘟嘴的親親表情"

#. Translators: (emoji) winking face with stuck out tongue.
#: addon\globalPlugins\emoticons\smileysList.py:51
msgid "Winking face with stuck out tongue"
msgstr "單眼眨眼且吐舌頭的搞怪表情"

#. Translators: (emoji) face with stuck out tongue and eyes tightly closed.
#: addon\globalPlugins\emoticons\smileysList.py:53
msgid "Face with stuck out tongue and eyes tightly closed"
msgstr "緊閉雙眼成交叉狀且用力吐出舌頭的大笑開心表情"

#. Translators: (emoji) A cheeky face with stuck out tongue.
#: addon\globalPlugins\emoticons\smileysList.py:55
msgid "Face with stuck out tongue"
msgstr "睜大雙眼且吐舌頭的俏皮表情"

#. Translators: (emoji) Hugging Face: a face displayed with an open hands gesture, offering a hug.
#: addon\globalPlugins\emoticons\smileysList.py:57
msgid "Hugging face"
msgstr "張開雙手想擁抱的開心表情"

#. Translators: (emoji) flushed face.
#: addon\globalPlugins\emoticons\smileysList.py:59
msgid "Flushed face"
msgstr "臉紅且睜大雙眼的驚訝表情"

#. Translators: (emoji) Grinning face showing smiling eyes.
#: addon\globalPlugins\emoticons\smileysList.py:61
msgid "Grinning Face With Smiling Eyes"
msgstr "露齒大笑且帶有笑眼的開心表情"

#. Translators: (emoji) A pensive, remorseful and saddened face. Quietly considering where things all went wrong.
#: addon\globalPlugins\emoticons\smileysList.py:63
msgid "Pensive Face"
msgstr "垂頭喪氣且陷入沉思的憂鬱表情"

#. Translators: (emoji) devil with evil smile.
#: addon\globalPlugins\emoticons\smileysList.py:65
msgid "Devil with evil smile"
msgstr "帶有尖角且邪惡微笑的小惡魔表情"

#. Translators: (emoji) devil.
#: addon\globalPlugins\emoticons\smileysList.py:67
msgid "Devil"
msgstr "帶有尖角的紫色小惡魔"

#. Translators: (emoji) relieved face.
#: addon\globalPlugins\emoticons\smileysList.py:69
msgid "Relieved face"
msgstr "感到如釋重負的安心表情"

#. Translators: (emoji) unamused face.
#: addon\globalPlugins\emoticons\smileysList.py:71
msgid "Unamused face"
msgstr "斜眼看人且感到不屑的表情"

#. Translators: (emoji) A face with scrunched up and closed eyes, frowning. Used to show helplessness in a situation.
#: addon\globalPlugins\emoticons\smileysList.py:73
msgid "Persevering Face"
msgstr "緊咬牙關且努力忍耐的堅毅表情"

#. Translators: (emoji) crying face.
#: addon\globalPlugins\emoticons\smileysList.py:75
msgid "Crying face"
msgstr "流下一滴眼淚的難過表情"

#. Translators: (emoji) face with tears of joy.
#: addon\globalPlugins\emoticons\smileysList.py:77
msgid "Face with tears of joy"
msgstr "笑到流下眼淚的極度開心表情"

#. Translators: (emoji) loudly crying face.
#: addon\globalPlugins\emoticons\smileysList.py:79
msgid "Loudly crying face"
msgstr "放聲大哭且淚流滿面的崩潰表情"

#. Translators: (emoji) sleepy face.
#: addon\globalPlugins\emoticons\smileysList.py:81
msgid "Sleepy face"
msgstr "帶有鼻涕泡且昏昏欲睡的表情"

#. Translators: (emoji) Shrugging: A person shrugging their shoulders to indicate a lack of knowledge about a particular topic, or a lack of care about the result of a situation.
#: addon\globalPlugins\emoticons\smileysList.py:83
msgid "Shrugging emoji"
msgstr "兩手一攤且表示無奈的撇嘴表情"

#. Translators: (emoji) disappointed face.
#: addon\globalPlugins\emoticons\smileysList.py:85
msgid "Disappointed face"
msgstr "嘴角下垂且感到失望的沮喪表情"

#. Translators: (emoji) disappointed but relieved face.
#: addon\globalPlugins\emoticons\smileysList.py:87
msgid "Disappointed but relieved face"
msgstr "流下一滴冷汗且感到鬆一口氣的表情"

#. Translators: (emoji) Face with a look of concern, with a blue forehead and sweat dripping down the cheek.
#: addon\globalPlugins\emoticons\smileysList.py:89
msgid "Face With Open Mouth & Cold Sweat"
msgstr "張大嘴巴大笑且流下冷汗的尷尬表情(苦笑)"

#. Translators: (emoji) Happy face with a single drop of sweat on one side of the face.
#: addon\globalPlugins\emoticons\smileysList.py:91
msgid "Smiling Face With Open Mouth & Cold Sweat"
msgstr "張大口大笑且額頭流下冷汗的尷尬表情"

#. Translators: (emoji) face with cold sweat.
#: addon\globalPlugins\emoticons\smileysList.py:93
msgid "Face with cold sweat"
msgstr "流下冷汗且感到焦慮不安的恐懼表情"

#. Translators: (emoji) A distraught-looking face with  an open mouth and crescent shaped eyes.
#: addon\globalPlugins\emoticons\smileysList.py:95
msgid "Weary Face"
msgstr "感到心力交瘁且極度疲累的表情"

#. Translators: (emoji) An exhausted-looking face with an open mouth and tightly closed eyes.
#: addon\globalPlugins\emoticons\smileysList.py:97
msgid "Tired Face"
msgstr "緊閉雙眼且感到疲倦掙扎的表情"

#. Translators: (emoji) fearful face.
#: addon\globalPlugins\emoticons\smileysList.py:99
msgid "Fearful face"
msgstr "瞪大雙眼且感到驚恐的害怕表情"

#. Translators: (emoji) face screaming in fear.
#: addon\globalPlugins\emoticons\smileysList.py:101
msgid "Face screaming in fear"
msgstr "雙手托腮且張口大聲尖叫的極度驚恐表情(驚恐)"

#. Translators: (emoji) angry face.
#. Translators: :@ angry face.
#: addon\globalPlugins\emoticons\smileysList.py:103
#: addon\globalPlugins\emoticons\smileysList.py:195
msgid "Angry face"
msgstr "眉頭深鎖且感到生氣的不悅表情"

#. Translators: (emoji) pouting face.
#: addon\globalPlugins\emoticons\smileysList.py:105
msgid "Pouting face"
msgstr "臉色發紅且極度憤怒的生氣表情"

#. Translators: (emoji) A face with air coming out of its nose, huffing with anger face.
#: addon\globalPlugins\emoticons\smileysList.py:107
msgid "Face With Steam From Nose"
msgstr "鼻孔噴出白煙且感到憤慨的生氣表情"

#. Translators: (emoji) confounded face.
#: addon\globalPlugins\emoticons\smileysList.py:109
msgid "Confounded face"
msgstr "感到困惑且不知所措的混亂表情"

#. Translators: (emoji) Smiling Face With Open Mouth and Tightly-Closed Eyes.
#: addon\globalPlugins\emoticons\smileysList.py:111
msgid "Smiling Face With Open Mouth and Tightly-Closed Eyes"
msgstr "張大口開懷大笑且緊緊閉上雙眼呈現大笑的開心表情"

#. Translators: (emoji) happy face licking lips.
#: addon\globalPlugins\emoticons\smileysList.py:113
msgid "Happy face licking lips"
msgstr "舔嘴巴且感到心滿意足的開心表情"

#. Translators: (emoji) happy face with sunglasses.
#: addon\globalPlugins\emoticons\smileysList.py:115
msgid "Happy face with sunglasses"
msgstr "戴著黑色太陽眼鏡且顯得酷帥自信的開心表情"

#. Translators: (emoji) sleeping face.
#: addon\globalPlugins\emoticons\smileysList.py:117
msgid "Sleeping face"
msgstr "緊閉雙眼且帶有睡意符號的熟睡表情(睡覺)"

#. Translators: (emoji) A dizzy face, looking sick or confused from being spun around in circles too many times.
#: addon\globalPlugins\emoticons\smileysList.py:119
msgid "Dizzy Face"
msgstr "雙眼呈現叉叉狀且感到極度暈眩的表情"

#. Translators: (emoji) astonished face.
#: addon\globalPlugins\emoticons\smileysList.py:121
msgid "Astonished face"
msgstr "睜大圓眼且感到驚訝萬分的表情"

#. Translators: (emoji) worried face.
#: addon\globalPlugins\emoticons\smileysList.py:123
msgid "Worried face"
msgstr "眉頭微皺且感到擔憂不安的表情"

#. Translators: (emoji) Dismayed face with open eyes and open mouth, appear closer to  a frowning face.
#: addon\globalPlugins\emoticons\smileysList.py:125
msgid "Frowning Face With Open Mouth"
msgstr "眉頭深鎖且張開嘴巴表示驚愕的表情"

#. Translators: (emoji) anguished face.
#: addon\globalPlugins\emoticons\smileysList.py:127
msgid "Anguished face"
msgstr "眉頭緊鎖且感到極度痛苦的表情"

#. Translators: (emoji) A face with Open Mouth, generally used to represent an element of surprise.
#: addon\globalPlugins\emoticons\smileysList.py:129
msgid "Face with Open Mouth"
msgstr "張開嘴巴且感到驚訝的表情(驚訝)"

#. Translators: (emoji) grimacing face.
#: addon\globalPlugins\emoticons\smileysList.py:131
msgid "Grimacing face"
msgstr "緊咬牙關且感到尷尬不安的表情"

#. Translators: (emoji) confused face.
#: addon\globalPlugins\emoticons\smileysList.py:133
msgid "Confused face"
msgstr "歪著嘴角且感到困惑猶疑的表情"

#. Translators: (emoji) A face with high eyebrows and an open mouth, it looks more surprised than hushed.
#: addon\globalPlugins\emoticons\smileysList.py:135
msgid "Hushed Face"
msgstr "睜大雙眼且顯得安靜驚訝的表情"

#. Translators: (emoji) broken heart.
#: addon\globalPlugins\emoticons\smileysList.py:137
msgid "Broken heart"
msgstr "心碎"

#. Translators: (emoji) pulsating heart.
#: addon\globalPlugins\emoticons\smileysList.py:139
msgid "Pulsating heart"
msgstr "帶有震動波紋且正在跳動的愛心符號(熱戀)"

#. Translators: (emoji) beating heart.
#: addon\globalPlugins\emoticons\smileysList.py:141
msgid "Beating heart"
msgstr "帶有放射狀線條且強烈跳動的愛心符號(心跳聲)"

#. Translators: (emoji) two hearts.
#: addon\globalPlugins\emoticons\smileysList.py:143
msgid "Two hearts"
msgstr "兩顆交疊且充滿愛意的愛心符號(浪漫)"

#. Translators: (emoji) heart with arrow.
#: addon\globalPlugins\emoticons\smileysList.py:145
msgid "Heart with arrow"
msgstr "被一支箭從中間斜穿過且陷入愛河的愛心符號(一見鍾情)"

#. Translators: (emoji) purple heart.
#: addon\globalPlugins\emoticons\smileysList.py:147
msgid "Purple heart"
msgstr "紫色愛心"

#. Translators: (emoji) red heart.
#: addon\globalPlugins\emoticons\smileysList.py:149
msgid "Red heart"
msgstr "紅色愛心"

#. Translators: (emoji) yellow heart.
#: addon\globalPlugins\emoticons\smileysList.py:151
msgid "Yellow heart"
msgstr "黃色愛心"

#. Translators: (emoji) green heart.
#: addon\globalPlugins\emoticons\smileysList.py:153
msgid "Green heart"
msgstr "綠色愛心"

#. Translators: (emoji) blue heart.
#: addon\globalPlugins\emoticons\smileysList.py:155
msgid "Blue heart"
msgstr "藍色愛心"

#. Translators: (emoji) This emoji is the version of the phrase ROFL. A person lying on the floor due to an extreme amount of laughter.
#: addon\globalPlugins\emoticons\smileysList.py:157
msgid "Rolling on the Floor Laughing"
msgstr "身體傾斜且在地上打滾大笑的極度狂笑表情(笑得滿地打滾)"

#. Translators: (emoji) A face that is a little bit sad, with a slight frown and neutral eyes.
#: addon\globalPlugins\emoticons\smileysList.py:159
msgid "Slightly Frowning Face"
msgstr "嘴角微微下垂且感到些許失望的不悅表情(有點失望)"

#. Translators: (emoji) A face that is upside-down.
#: addon\globalPlugins\emoticons\smileysList.py:161
msgid "Upside-down Face"
msgstr "顛倒翻轉且帶有幽默自嘲感的開心表情"

#. Translators: (emoji) A face displaying eyes glancing upward.
#: addon\globalPlugins\emoticons\smileysList.py:163
msgid "Face With Rolling Eyes"
msgstr "雙眼向上翻動且感到不耐煩的表情(翻白眼)"

#. Translators: (emoji) A person with arms forming an X to indicate no or no good.
#: addon\globalPlugins\emoticons\smileysList.py:165
msgid "Person Gesturing No"
msgstr "雙手在胸前交叉並做出拒絕手勢的人物表情"

#. Translators: (emoji) A person with arms above his head, making an OK sign with the whole body.
#: addon\globalPlugins\emoticons\smileysList.py:167
msgid "Person Gesturing OK"
msgstr "雙手舉過頭頂並做出圓形確認手勢的人物表情"

#. Translators: (emoji) A person bowing deeply, express a sincere apology or to request a favour.
#: addon\globalPlugins\emoticons\smileysList.py:169
msgid "Person bowing"
msgstr "上半身前傾且表現出誠懇謝意的鞠躬人物表情"

#. Translators: (emoji) An upset person frowning with dismay.
#: addon\globalPlugins\emoticons\smileysList.py:171
msgid "Person Frowning"
msgstr "嘴角下垂且顯得憂傷失望的皺眉人物表情"

#. Translators: (emoji) Two hands placed firmly together.
#: addon\globalPlugins\emoticons\smileysList.py:173
msgid "Folded Hands"
msgstr "雙手合十且表示祈禱或感謝的手勢符號(拜託或感謝)"

#. Translators: (emoji) A person with a surgical mask on their face.
#: addon\globalPlugins\emoticons\smileysList.py:175
msgid "Face with medical mask"
msgstr "戴著醫用口罩且顯得身體不適的防護表情(感冒)"

#. Translators: (emoji) A black version of white smiling face.
#: addon\globalPlugins\emoticons\smileysList.py:177
msgid "Black Smiling Face"
msgstr "呈現黑色實心外觀且帶有微笑的表情"

#. Translators: (emoji) happy cat face with heart shaped eyes.
#: addon\globalPlugins\emoticons\smileysList.py:179
msgid "Happy cat face with heart shaped eyes"
msgstr "雙眼呈現紅色心形且感到極度著迷的貓咪笑臉表情"

#. Translators: (emoji) ok hand sign.
#: addon\globalPlugins\emoticons\smileysList.py:181
msgid "Ok hand sign"
msgstr "拇指與食指捏成圓圈表示讚同的 OK 手勢"

#. Translators: (emoji) thumbs up symbol.
#: addon\globalPlugins\emoticons\smileysList.py:183
msgid "Thumbs up symbol"
msgstr "豎起大拇指且表示做得好或讚賞的手勢(讚)"

#. Translators: (emoji) thumbs down symbol.
#: addon\globalPlugins\emoticons\smileysList.py:185
msgid "Thumbs down symbol"
msgstr "向下垂下大拇指且表示差勁或反對的手勢"

#. Translators: (emoji) Victory Hand.
#: addon\globalPlugins\emoticons\smileysList.py:187
msgid "Victory Hand"
msgstr "食指與中指張開呈現 V 字型的愛心或勝利手勢"

#. Translators: :) Smile
#: addon\globalPlugins\emoticons\smileysList.py:189
msgid "smiling smiley"
msgstr "呈現簡單線條且帶有親切微笑的表情"

#. Translators: :( Sad face.
#: addon\globalPlugins\emoticons\smileysList.py:191
msgid "Sad face"
msgstr "嘴角下垂且顯得心情低落的表情"

#. Translators: :D Laugh
#: addon\globalPlugins\emoticons\smileysList.py:193
msgid "Laughing smiley"
msgstr "張大口大笑且感到非常有趣的表情"

#. Translators: :O Surprised
#: addon\globalPlugins\emoticons\smileysList.py:197
msgid "surprised smiley"
msgstr "睜大雙眼且張開圓嘴感到意外的表情(吃驚)"

#. Translators: ;) Wink;
#: addon\globalPlugins\emoticons\smileysList.py:199
msgid "winking smiley"
msgstr "閉上一隻眼睛且帶有幽默感的眨眼微笑表情"

#. Translators: ;( Crying
#: addon\globalPlugins\emoticons\smileysList.py:201
msgid "crying smiley"
msgstr "流出一滴眼淚且感到委屈憂傷的表情"

#. Translators: :s :-S :-Q Confused face:
#: addon\globalPlugins\emoticons\smileysList.py:203
msgid "Confused Face"
msgstr "嘴角歪斜且顯得懷疑不解的表情(困惑)"

#. Translators: (:| Sweating
#: addon\globalPlugins\emoticons\smileysList.py:205
msgid "sweating smiley"
msgstr "額頭流下一滴汗珠且顯得尷尬心虛的微笑表情(心虛)"

#. Translators: :|] Robot (a robot head)
#: addon\globalPlugins\emoticons\smileysList.py:207
msgid "Robot Smiley"
msgstr "具有金屬方頭且帶有機械感的小機器人表情"

#. Translators: :| Speechless
#: addon\globalPlugins\emoticons\smileysList.py:209
msgid "speechless smiley"
msgstr "完全沒有嘴巴且顯得沈默無言的空白表情"

#. Translators: :* Kiss
#: addon\globalPlugins\emoticons\smileysList.py:211
msgid "kiss smiley"
msgstr "嘴唇噘起並做出親吻動作的表情符號(愛慕)"

#. Translators: :P Cheeky
#: addon\globalPlugins\emoticons\smileysList.py:213
msgid "cheeky smiley"
